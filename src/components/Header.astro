---
---

<header class="site-header">
  <div class="site-header__inner">
    <a href="#inicio" class="brand-link" aria-label="Benedetta Paglacci">
      <img src="/images/logo.png" alt="Benedetta Paglacci" class="brand-link__logo" width="56" height="56" />
      <span class="brand-link__text">
        <strong>Benedetta Paglacci</strong>
        <small>Pizza artesanal</small>
      </span>
    </a>

    <nav class="main-nav" aria-label="Navegação principal">
      <a href="#cardapio">Cardápio</a>
      <a href="#tamanhos">Tamanhos</a>
      <a href="#pedido">Pedido</a>
    </nav>

    <button id="openCartButton" class="cart-trigger" type="button" aria-controls="cartDrawer" aria-expanded="false" data-open-cart>
      <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.9">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h2l2.1 10.1a2 2 0 0 0 2 1.6h7.8a2 2 0 0 0 2-1.6L20 8H7" />
        <circle cx="10" cy="19" r="1.25"></circle>
        <circle cx="17" cy="19" r="1.25"></circle>
      </svg>
      <span>Carrinho</span>
      <strong data-cart-count>0</strong>
    </button>
  </div>
</header>
